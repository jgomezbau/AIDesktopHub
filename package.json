{
  "name": "aidesktophub",
  "version": "2.0.1",
  "description": "Linux desktop wrapper for ChatGPT, Claude, Gemini, Grok, DeepSeek, Qwen, and Z.ai",
  "homepage": "https://github.com/jgomezbau/AIDesktopHub",
  "author": "Juan Bau <jgomezbau@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgomezbau/AIDesktopHub.git"
  },
  "bugs": {
    "url": "https://github.com/jgomezbau/AIDesktopHub/issues"
  },
  "main": "src/main/index.js",
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "scripts": {
    "test": "node --test",
    "check:syntax": "node -c src/main/apps.js && node -c src/main/index.js && node -c src/main/ipc.js && node -c src/main/runtime-flags.js && node -c src/preload/preload.js && node -c src/preload/clipboard-fix.js && node -c src/preload/inject-styles.js",
    "ci": "npm run check:syntax && npm test && npm run build:dir",
    "start": "electron .",
    "start:chatgpt": "electron . --app=chatgpt",
    "start:claude": "electron . --app=claude",
    "start:gemini": "electron . --app=gemini",
    "start:grok": "electron . --app=grok",
    "start:deepseek": "electron . --app=deepseek",
    "start:qwen": "electron . --app=qwen",
    "start:zai": "electron . --app=zai",
    "dev": "electron . --enable-logging",
    "dev:chatgpt": "electron . --enable-logging --app=chatgpt",
    "dev:claude": "electron . --enable-logging --app=claude",
    "dev:gemini": "electron . --enable-logging --app=gemini",
    "dev:grok": "electron . --enable-logging --app=grok",
    "dev:deepseek": "electron . --enable-logging --app=deepseek",
    "dev:qwen": "electron . --enable-logging --app=qwen",
    "dev:zai": "electron . --enable-logging --app=zai",
    "debug": "electron --inspect=5858 .",
    "build:dir": "electron-builder --dir",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "io.github.jgomezbau.AIDesktopHub",
    "productName": "AI Desktop Hub",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "package.json",
      "package-lock.json",
      "src/**/*",
      "assets/**/*",
      "LICENSE",
      "!dist/**/*",
      "!*.code-workspace",
      "!**/*.ts"
    ],
    "extraResources": [
      {
        "from": "assets/icons/aidesktophub.png",
        "to": "assets/icons/aidesktophub.png"
      },
      {
        "from": "assets/linux",
        "to": "assets/linux"
      },
      {
        "from": "assets/icons/providers",
        "to": "assets/icons/providers"
      }
    ],
    "linux": {
      "executableName": "AIDesktopHub",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Utility",
      "synopsis": "Linux desktop wrapper for AI web apps",
      "description": "Desktop wrapper for ChatGPT, Claude, Gemini, Grok, DeepSeek, Qwen, and Z.ai with isolated sessions per provider.",
      "desktop": {
        "Name": "AI Desktop Hub",
        "Comment": "Desktop hub for AI assistants on Linux",
        "Categories": "Utility;Network;Chat;",
        "StartupWMClass": "AIDesktopHub"
      },
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "icons/aidesktophub.png"
    },
    "appImage": {
      "license": "LICENSE"
    },
    "deb": {
      "packageName": "aidesktophub",
      "afterInstall": "assets/linux/scripts/postinst.sh",
      "afterRemove": "assets/linux/scripts/postrm.sh",
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    }
  },
  "devDependencies": {
    "electron": "41.1.0",
    "electron-builder": "24.13.3"
  },
  "license": "MIT"
}
